# Shopify CRO Agent — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is git-ignored — your secrets stay local and are never committed.
#
# Required for: weekly scan (run_agent.py --weekly)
# Optional: Slack, email, dev agent

# ---------------------------------------------------------------------------
# Shopify Admin API (REQUIRED)
# ---------------------------------------------------------------------------
# Create a custom app: Shopify Admin > Settings > Apps and sales channels > Develop apps
# Required scopes: read_orders, read_checkouts, read_products, read_customers, read_analytics
#
# IMPORTANT: Only grant READ scopes. The agent never needs to write to your store.
# Do NOT grant write_products, write_themes, or any other write scope.

SHOPIFY_SHOP_URL=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2025-01

# ---------------------------------------------------------------------------
# Theme directory (REQUIRED for theme analysis)
# ---------------------------------------------------------------------------
# Download your theme locally:
#   shopify theme pull --store your-store.myshopify.com --path ./theme
#
# SAFE TO USE YOUR LIVE/PUBLISHED THEME.
# The agent only READS theme files — it never uploads, modifies, or publishes.
# "shopify theme pull" downloads a local copy. Your live theme is not affected.
#
# Using the live theme is actually recommended — it ensures the agent analyses
# what customers actually see, not an outdated dev copy.
#
# If you prefer to use an unpublished/dev theme, find its ID in:
#   Shopify Admin > Online Store > Themes > ... (Actions) > Edit code
#   The theme ID is the number in the URL.
# Then pull it with:
#   shopify theme pull --store your-store.myshopify.com --theme THEME_ID --path ./theme

THEME_DIR=/path/to/your/shopify/theme

# ---------------------------------------------------------------------------
# Anthropic API (REQUIRED for report synthesis)
# ---------------------------------------------------------------------------
# Get your key: https://console.anthropic.com

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Slack notifications (OPTIONAL)
# ---------------------------------------------------------------------------
# Two options for receiving notifications:
#
# OPTION A: DM to yourself (recommended)
#   1. Create a private Slack channel with just yourself (e.g. #cro-alerts)
#   2. Create an incoming webhook for that channel:
#      Slack > Apps > Incoming Webhooks > Add to Slack > choose your private channel
#   3. Paste the webhook URL below
#   This is effectively a DM — only you see the messages.
#
# OPTION B: Bot token for real DMs (advanced)
#   1. Create a Slack app at https://api.slack.com/apps
#   2. Add the chat:write scope under OAuth & Permissions
#   3. Install to your workspace
#   4. Set SLACK_BOT_TOKEN below (starts with xoxb-)
#   5. Set SLACK_DM_USER_ID to your Slack member ID
#      (find it: click your profile > ... > Copy member ID)
#   The agent will DM you directly.
#
# Use ONE option, not both. If both are set, bot token takes priority.

SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=
SLACK_DM_USER_ID=

# ---------------------------------------------------------------------------
# Email notifications (OPTIONAL)
# ---------------------------------------------------------------------------
# Your SMTP provider settings (Gmail, SendGrid, Postmark, etc.)
# For Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587
# You'll need an "App Password" — not your regular Gmail password.

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=

# ---------------------------------------------------------------------------
# GitHub Actions / Dev Agent (OPTIONAL — only needed for CI/CD automation)
# ---------------------------------------------------------------------------
# These are set as GitHub repo secrets (Settings > Secrets), not in .env locally.
# Listed here for reference only.
#
# SHOPIFY_THEME_ID — the numeric ID of your live or dev theme
#   Find it: Shopify Admin > Online Store > Themes > ... > Edit code > number in URL
#
# SHOPIFY_THEME_REPO — the GitHub repo containing your Shopify theme
#   e.g. your-org/your-theme-repo
#
# THEME_REPO_PAT — a GitHub Personal Access Token with 'repo' scope
#   Used by the dev agent to clone the theme repo and open PRs
#   Create at: https://github.com/settings/tokens
#
# SHOPIFY_THEME_ID=123456789
# SHOPIFY_THEME_REPO=your-org/your-theme-repo
# THEME_REPO_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
